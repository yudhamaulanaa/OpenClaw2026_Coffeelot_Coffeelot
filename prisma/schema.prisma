generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  businessType String   @default("coffee_shop") @map("business_type")
  status       String   @default("active")
  timezone     String   @default("Asia/Jakarta")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenantUsers      TenantUser[]
  outlets          Outlet[]
  products         Product[]
  inventoryItems   InventoryItem[]
  productRecipes   ProductRecipe[]
  customers        Customer[]
  orders           Order[]
  orderItems       OrderItem[]
  stockMovements   StockMovement[]
  chatCartSessions ChatCartSession[]
  qrOrderLinks     QrOrderLink[]
  bookings         Booking[]
  agentRuns        AgentRun[]
  agentOutputs     AgentOutput[]
  aiReports        AiReport[]
  payments         Payment[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenantUsers TenantUser[]

  @@map("users")
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_users")
}

model Outlet {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant           Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products         Product[]
  inventoryItems   InventoryItem[]
  orders           Order[]
  stockMovements   StockMovement[]
  chatCartSessions ChatCartSession[]
  qrOrderLinks     QrOrderLink[]
  bookings         Booking[]
  agentRuns        AgentRun[]
  aiReports        AiReport[]
  payments         Payment[]

  @@index([tenantId])
  @@map("outlets")
}

model Product {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  outletId  String?  @map("outlet_id")
  name      String
  category  String
  price     Decimal
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet        Outlet? @relation(fields: [outletId], references: [id], onDelete: SetNull)
  recipes       ProductRecipe[]
  orderItems    OrderItem[]
  chatCartItems ChatCartItem[]

  @@index([tenantId])
  @@index([outletId])
  @@map("products")
}

model InventoryItem {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  outletId     String   @map("outlet_id")
  name         String
  unit         String
  currentStock Decimal  @map("current_stock")
  minimumStock Decimal  @map("minimum_stock")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet         Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  recipes        ProductRecipe[]
  stockMovements StockMovement[]

  @@index([tenantId])
  @@index([outletId])
  @@map("inventory_items")
}

model ProductRecipe {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  productId       String   @map("product_id")
  inventoryItemId String   @map("inventory_item_id")
  qtyUsed         Decimal  @map("qty_used")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([productId, inventoryItemId])
  @@index([tenantId])
  @@index([inventoryItemId])
  @@map("product_recipes")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([tenantId])
  @@map("customers")
}

model Order {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  outletId       String   @map("outlet_id")
  customerId     String?  @map("customer_id")
  invoiceNumber  String?  @map("invoice_number")
  orderStatus    String   @default("draft") @map("order_status")
  prepStatus     String   @default("new") @map("prep_status")
  orderChannel   String   @default("cashier") @map("order_channel")
  tableLabel     String?  @map("table_label")
  paymentMethod  String   @map("payment_method")
  subtotal       Decimal
  discount       Decimal  @default(0)
  total          Decimal
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet         Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  stockMovements StockMovement[]
  payments       Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([outletId])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  orderId     String   @map("order_id")
  productId   String   @map("product_id")
  productName String   @map("product_name")
  qty         Int
  unitPrice   Decimal  @map("unit_price")
  totalPrice  Decimal  @map("total_price")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model StockMovement {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  outletId        String   @map("outlet_id")
  inventoryItemId String   @map("inventory_item_id")
  movementType    String   @map("movement_type")
  qty             Decimal
  stockBefore     Decimal  @map("stock_before")
  stockAfter      Decimal  @map("stock_after")
  orderId         String?  @map("order_id")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet        Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  order         Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([outletId])
  @@index([inventoryItemId])
  @@index([orderId])
  @@map("stock_movements")
}

model ChatCartSession {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  outletId        String   @map("outlet_id")
  tableLabel      String?  @map("table_label")
  status          String   @default("active")
  customerName    String?  @map("customer_name")
  customerContact String?  @map("customer_contact")
  sourceChannel   String?  @map("source_channel")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items  ChatCartItem[]

  @@index([tenantId])
  @@index([outletId])
  @@map("chat_cart_sessions")
}

model ChatCartItem {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  productId  String?  @map("product_id")
  itemName   String   @map("item_name")
  qty        Int
  unitPrice  Decimal  @map("unit_price")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  session ChatCartSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([productId])
  @@map("chat_cart_items")
}

model QrOrderLink {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  outletId   String   @map("outlet_id")
  tableLabel String?  @map("table_label")
  token      String   @unique
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([outletId])
  @@map("qr_order_links")
}

model Booking {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  outletId        String   @map("outlet_id")
  customerName    String   @map("customer_name")
  customerContact String?  @map("customer_contact")
  partySize       Int      @map("party_size")
  bookingStart    DateTime @map("booking_start")
  bookingEnd      DateTime @map("booking_end")
  status          String   @default("reserved")
  tableLabel      String?  @map("table_label")
  notes           String?
  arrivedAt       DateTime? @map("arrived_at")
  releasedAt      DateTime? @map("released_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([outletId])
  @@index([bookingStart])
  @@index([bookingEnd])
  @@map("bookings")
}

model AgentRun {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  outletId     String   @map("outlet_id")
  workflowId   String   @map("workflow_id")
  triggerType  String   @map("trigger_type")
  status       String   @default("running")
  startedAt    DateTime @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet  Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  outputs AgentOutput[]

  @@index([tenantId])
  @@index([outletId])
  @@map("agent_runs")
}

model AgentOutput {
  id               String   @id @default(uuid())
  runId            String   @map("run_id")
  tenantId         String   @map("tenant_id")
  outputType       String   @map("output_type")
  title            String
  content          String
  metadata         String?
  requiresApproval Boolean  @default(false) @map("requires_approval")
  approved         Boolean?
  approvedAt       DateTime? @map("approved_at")
  createdAt        DateTime @default(now()) @map("created_at")

  run    AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([tenantId])
  @@map("agent_outputs")
}

model AiReport {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  outletId          String   @map("outlet_id")
  reportDate        DateTime @map("report_date")
  reportType        String   @default("daily") @map("report_type")
  inputSnapshot     String   @map("input_snapshot")
  aiSummary         String   @map("ai_summary")
  aiRecommendations String   @map("ai_recommendations")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([outletId])
  @@map("ai_reports")
}

model Payment {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  outletId       String   @map("outlet_id")
  orderId        String   @map("order_id")
  dokuInvoiceId  String?  @map("doku_invoice_id")
  paymentMethod  String   @map("payment_method")
  amount         Decimal
  status         String   @default("pending")
  paymentUrl     String?  @map("payment_url")
  qrCode         String?  @map("qr_code")
  vaNumber       String?  @map("va_number")
  paidAt         DateTime? @map("paid_at")
  expiredAt      DateTime @map("expired_at")
  rawResponse    String?  @map("raw_response")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([outletId])
  @@index([orderId])
  @@map("payments")
}
