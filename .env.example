# Coffeelot environment example
# Copy to .env for local development. Do not commit real secrets.

# Database
DATABASE_URL="file:./dev.db"

# Demo context fallback for MVP/local development
DEMO_TENANT_ID=""
DEMO_OUTLET_ID=""

# API
API_HOST="127.0.0.1"
API_PORT="3001"

# Web
VITE_API_BASE_URL="https://api.coffeelot.app/api"

# AI provider — OpenAI-compatible API
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL=""

# DOKU MCP sandbox placeholders — never commit real credentials
DOKU_ENV="sandbox"
DOKU_CLIENT_ID=""
DOKU_API_KEY=""
DOKU_SECRET_KEY=""
DOKU_MCP_URL="https://api-sandbox.doku.com/doku-mcp-server/mcp"
DOKU_CALLBACK_URL="https://api.coffeelot.app/api/payments/callback"
DOKU_RETURN_URL="https://coffeelot.app"

# Agent scheduler
AGENT_SCHEDULER_ENABLED="true"
AGENT_SCHEDULER_TENANT_ID="demo-tenant-kopi-jagoan"
AGENT_SCHEDULER_OUTLET_ID="demo-outlet-booth-ciputat"
AGENT_SCHEDULER_INITIAL_DELAY_MS="5000"
AGENT_DAILY_REPORT_INTERVAL_MS="86400000"
AGENT_RESTOCK_ALERT_INTERVAL_MS="3600000"
