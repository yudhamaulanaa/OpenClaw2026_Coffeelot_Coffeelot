# Coffeelot environment example
# Copy to .env for local development. Do not commit real secrets.

# Database
DATABASE_URL="file:./dev.db"

# Demo context fallback for MVP/local development
DEMO_TENANT_ID=""
DEMO_OUTLET_ID=""

# API
API_HOST="127.0.0.1"
API_PORT="3001"

# Web
VITE_API_BASE_URL="http://127.0.0.1:3001/api"

# AI provider — OpenAI-compatible API
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL=""

# DOKU MCP sandbox placeholders
DOKU_API_KEY=""
DOKU_MCP_URL="https://mcp-sandbox.doku.com/sse"
